<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        IMPORTANT: Must extend a "NoActionBar" variant.
        If the theme provides its own WindowDecorActionBar, Android ignores
        setSupportActionBar() in MainActivity — the MaterialToolbar never
        becomes the real action bar, so MenuProvider events never fire and
        the three-dot overflow menu does not open.

        Theme.Material3.DayNight.NoActionBar is the correct M3 base.
        If you need a light-only theme, use Theme.Material3.Light.NoActionBar.
    -->
    <style name="Theme.ValentinesGarage" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand colour — red used on the app bar and buttons -->
        <item name="colorPrimary">@color/red_700</item>
        <item name="colorPrimaryVariant">@color/red_900</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary / accent colour -->
        <item name="colorSecondary">@color/red_700</item>
        <item name="colorSecondaryVariant">@color/red_900</item>
        <item name="colorOnSecondary">@color/white</item>

        <!--
            Toolbar popup menu theme.
            Must be a Light overlay so the dropdown text is dark-on-white,
            regardless of the device's day/night mode.
        -->
        <item name="actionOverflowMenuStyle">@style/OverflowMenuStyle</item>
    </style>

    <!--
        Forces the overflow popup (three-dot menu) to display above or below
        the toolbar rather than covering it, and ensures correct text colours.
    -->
    <style name="OverflowMenuStyle" parent="Widget.Material3.PopupMenu.Overflow">
        <item name="overlapAnchor">false</item>
    </style>

</resources>
