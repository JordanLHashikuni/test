<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider path configuration.
    Tells Android which directories the app is allowed to share
    as content:// URIs when launching the camera intent.

    external-cache-path: app-specific external cache — cleared when
    the user clears app data, so no long-lived storage. Good for
    temporary camera captures before upload to Firebase Storage.

    Declared in AndroidManifest.xml under:
        android:resource="@xml/file_paths"
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <external-cache-path
        name="camera_captures"
        path="images/" />
</paths>
