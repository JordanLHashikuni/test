<?xml version="1.0" encoding="utf-8"?>
<!--
    Data Extraction Rules (Android 12+ / API 31+).
    Referenced by android:dataExtractionRules in AndroidManifest.xml.
    Applies to both cloud backup and device-to-device transfer.

    Mirror the exclusions in backup_rules.xml so the same sensitive
    data is protected under both the old and new backup systems.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="cache" path="." />
        <exclude domain="external-cache" path="." />
    </cloud-backup>

    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="cache" path="." />
        <exclude domain="external-cache" path="." />
    </device-transfer>
</data-extraction-rules>
