<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!--
        FIX 1: android:visible was "false" in the original, which means the item
        is hidden before onCreateMenu() even runs. On some API levels the system
        snapshots visibility at inflation time and ignores the runtime isVisible
        assignment that comes a few milliseconds later (after the Firestore role
        fetch completes). Starting as visible="true" and letting onCreateMenu()
        hide it for mechanics is the correct pattern — the menu is only shown
        to users who are already past the login screen, so the brief flash risk
        is negligible and is eliminated entirely by the StateFlow invalidation.

        FIX 2: Renamed from "Add Staff" to "Add Mechanic" to match the screen
        label and make the action self-explanatory in the UI.
    -->
    <item
        android:id="@+id/action_add_mechanic"
        android:title="Add Mechanic"
        android:visible="true"
        app:showAsAction="never" />

    <item
        android:id="@+id/action_logout"
        android:title="Logout"
        app:showAsAction="never" />

</menu>
